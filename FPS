        orig_get_aim = hookfunction(gun_handler.getAim, function(p0, p1)
            local sc = getgenv().DNS["Silent"]
            if not sc["Enabled"] or not sc["Main"]["Enabled"] then return orig_get_aim(p0,p1) end
            
            if not CachedAimPosition then return orig_get_aim(p0,p1) end
            
            -- Sniper: show perfect aim visuals on screen (redirected bullets, no spread)
            if sc["ClientBullet"]["Mode"] == "Sniper" then
                local dir = CachedAimPosition - p0
                return dir.Unit, dir.Magnitude
            end
            
            -- LegitSniper: redirect on ALL guns, but visuals differ
            if sc["ClientBullet"]["Mode"] == "LegitSniper" then
                if IsRevolverEquipped() then
                    -- Revolver: show normal aim visuals (for clips), ClientBullet handles perfect bullets
                    return orig_get_aim(p0,p1)
                else
                    -- Other guns: redirect to target (Silent Aim) but keep normal gun spread
                    local dir = CachedAimPosition - p0
                    return dir.Unit, dir.Magnitude
                end
            end
            
            -- LegitRedirection: only works on revolver, always show perfect aim visuals
            if sc["ClientBullet"]["Mode"] == "LegitRedirection" and IsRevolverEquipped() then
                local dir = CachedAimPosition - p0
                return dir.Unit, dir.Magnitude
            end
            
            -- If ClientBullet disabled (fallback): redirect for Silent Aim with gun spread
            if not sc["ClientBullet"]["Enabled"] then
                local dir = CachedAimPosition - p0
                return dir.Unit, dir.Magnitude
            end
            
            -- Normal: return normal aim (shoot hook handles redirection with spread)
            return orig_get_aim(p0,p1)
        end)
    end
