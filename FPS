    -- Dynamic ClientBullet hook - check every frame
    table.insert(DNS_Connections, game:GetService("RunService").Heartbeat:Connect(function()
        local cb_enabled = getgenv().DNS["Silent"]["ClientBullet"]["Enabled"]
        local cb_mode = getgenv().DNS["Silent"]["ClientBullet"]["Mode"]
        
        -- LegitSniper only enables ClientBullet with revolver (other guns use Silent Aim only)
