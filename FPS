local function UpdateFOVVisual(fov_cfg, circle_draw, box_frame, box_stroke, target, distance)
    local is_box     = fov_cfg["Type"] == "Box"
    local show       = fov_cfg["ShowFOV"]
    local hrp        = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    local mv         = GetMouseVP()
    local focused    = false
 
    circle_draw.Visible = false
    box_frame.Visible   = false
 
    if not show then return focused end
 
    if is_box then
        if hrp then
            local bounds = GetBoxFOVBounds(fov_cfg, hrp)
            if bounds then
                focused = IsMouseInBoxFOV(bounds)
                box_frame.Position   = UDim2.fromOffset(bounds.X, bounds.Y)
                box_frame.Size       = UDim2.fromOffset(bounds.W, bounds.H)
                box_frame.Visible    = true
                box_stroke.Thickness = fov_cfg["Thickness"] or 1
                box_stroke.Color     = focused and fov_cfg["FocusColor"] or fov_cfg["Color"]
            end
        end
    else
        local radius = GetFOVRadius(fov_cfg, distance)
        local pos_2d = mv
        if hrp then
            local sp, on = c:WorldToViewportPoint(hrp.Position)
            if on then
                pos_2d  = vect2(sp.X, sp.Y)
                focused = (mv - pos_2d).Magnitude < radius
            end
        end
        circle_draw.Visible      = true
        circle_draw.Radius       = radius
        circle_draw.Color        = focused and fov_cfg["FocusColor"] or fov_cfg["Color"]
        circle_draw.Filled       = fov_cfg["Filled"]
        circle_draw.Transparency = fov_cfg["Transparency"]
        circle_draw.Thickness    = fov_cfg["Thickness"] or 1
        circle_draw.Position     = hrp and pos_2d or mv
    end
 
    return focused
end
 
table.insert(DNS_Connections, rs.RenderStepped:Connect(function()
    -- Cache weapon state OUTSIDE namecall to avoid recursive calls
    CachedHasWeapon = HasWeapon()
    
    local mv          = GetMouseVP()
    local cfov        = cfg_cfov()
    local sfov        = cfg_sfov()
    local trace       = cfg_trace()
    local cam         = cfg_cam()
    local target_dist = CTarget and GetTargetDistance(CTarget) or 0
    local silent_dist = SilentTarget and GetTargetDistance(SilentTarget) or 0
 
    UpdateFOVVisual(sfov,  SilentFOV,  SilentBoxFrame,  SilentBoxStroke,  SilentTarget, silent_dist)
    UpdateFOVVisual(cfov,  CamlockFOV, CamlockBoxFrame, CamlockBoxStroke, CTarget, target_dist)
 
    Line.Color        = trace["Color"]
    Line.Transparency = trace["Transparency"]
 
    if cfg_key360()["Enabled"] and Toggle then
        local ct = tick()
        local dt = math.min(ct - LastRenderTime, 0.01)
        LastRenderTime = ct
        c.CFrame      = c.CFrame * CFrame.fromAxisAngle(vect3(0,1,0), math.rad(cfg_key360()["RotationSpeed"]*dt))
        TotalRotation = TotalRotation + math.rad(cfg_key360()["RotationSpeed"]*dt)
        if TotalRotation >= FullCircleRotation then Toggle=false; TotalRotation=0 end
    end
 
    UpdateCachedAim()
 
    if getgenv().DNS["Camlock"]["Enabled"] and cam["Enabled"] and CTarget and IsAlive(CTarget) and PassesChecks(CTarget) then
        local dist     = GetTargetDistance(CTarget)
        local ap, apos = GetCamlockPosition(CTarget.Character, dist)
        
        -- Check weapon requirement
        local has_gun = HasWeapon()
        local weapon_ok = not getgenv().DNS["Camlock"]["WeaponCheck"] or has_gun
        
        -- Check first person requirement
        local camMode = GetCameraMode()
        local fp_ok = not getgenv().DNS["Camlock"]["FirstPersonCheck"] or (camMode == "First Person")
 
        if ap and apos and weapon_ok and fp_ok then
            local tp = cam["Shake"] and apos + vect3(
                math.random(-cam["ShakeValue"],cam["ShakeValue"]),
                math.random(-cam["ShakeValue"],cam["ShakeValue"]),
                math.random(-cam["ShakeValue"],cam["ShakeValue"])
            )*0.1 or apos
 
            local es = cam["EasingStyle"] or "Linear"
 
            local function get_cam_sm()
                local cm = cam["CameraMode"]
                if cm and cm["Enabled"] then
                    return GetDistanceSmoothness(cm["Smoothness_Distance"], dist) or cm["Smoothness"]
                end
                return GetDistanceSmoothness(cam["Smoothness_Distance"], dist) or cam["Smoothness"]
            end
 
            local function get_cam_es()
                local cm = cam["CameraMode"]
                if cm and cm["Enabled"] then return cm["EasingStyle"] or es end
                return es
            end
 
            local function get_mouse_sm()
                local mm = cam["MouseMode"]
                if mm and mm["Enabled"] then
                    return GetDistanceSmoothness(mm["Smoothness_Distance"], dist) or mm["Smoothness"]
                end
                return GetDistanceSmoothness(cam["Smoothness_Distance"], dist) or cam["MouseSmoothness"]
            end
 
            local function get_cam_pred()
                local cm = cam["CameraMode"]
                if cm and cm["Enabled"] and cm["Prediction"] then return cm["Prediction"] end
                return cam["Prediction"]
            end
 
            local function get_mouse_pred()
                local mm = cam["MouseMode"]
                if mm and mm["Enabled"] and mm["Prediction"] then return mm["Prediction"] end
                return cam["Prediction"]
            end
 
            if InCamlockFOV(CTarget, dist) then
                local mode = cam["FollowMode"]["Enabled"] and cam["FollowMode"]["Mode"] or "Camera"
 
                if mode == "Hybrid" then
                    if camMode == "First Person" then
                        local vel      = GetVelocity(CTarget.Character)
                        local pred_cfg = get_cam_pred()
                        local target_p = ApplyPrediction(apos, vel, pred_cfg, dist)
                        if cam["SmoothLock"] then
                            c.CFrame = EasedLerp(c.CFrame, cnew(c.CFrame.p, target_p), get_cam_sm(), get_cam_es())
                        else
                            c.CFrame = cnew(c.CFrame.p, target_p)
                        end
                    else
                        local vel      = GetVelocity(CTarget.Character)
                        local pred_cfg = get_mouse_pred()
                        local target_p = ApplyPrediction(apos, vel, pred_cfg, dist)
                        local sp, on_screen = c:WorldToViewportPoint(target_p)
                        local viewport = c.ViewportSize
                        if on_screen and sp.X >= 0 and sp.X <= viewport.X and sp.Y >= 0 and sp.Y <= viewport.Y then
                            mousemoverel((sp.X - mv.X) * get_mouse_sm(), (sp.Y - mv.Y) * get_mouse_sm())
                        end
                    end
                elseif mode == "Mouse" then
                    local vel      = GetVelocity(CTarget.Character)
                    local pred_cfg = get_mouse_pred()
                    local target_p = ApplyPrediction(apos, vel, pred_cfg, dist)
                    local sp, on_screen = c:WorldToViewportPoint(target_p)
                    local viewport = c.ViewportSize
                    if on_screen and sp.X >= 0 and sp.X <= viewport.X and sp.Y >= 0 and sp.Y <= viewport.Y then
                        mousemoverel((sp.X - mv.X) * get_mouse_sm(), (sp.Y - mv.Y) * get_mouse_sm())
                    end
                else
                    local vel      = GetVelocity(CTarget.Character)
                    local pred_cfg = get_cam_pred()
                    local target_p = ApplyPrediction(apos, vel, pred_cfg, dist)
                    if cam["SmoothLock"] then
                        c.CFrame = EasedLerp(c.CFrame, cnew(c.CFrame.p, target_p), get_cam_sm(), get_cam_es())
                    else
                        c.CFrame = cnew(c.CFrame.p, target_p)
                    end
                end
            end
 
            if trace["Enabled"] and CachedTracerPos then
                local ts     = c:WorldToViewportPoint(CachedTracerPos)
                Line.Visible = true
                Line.From    = mv
                Line.To      = vect2(ts.X, ts.Y)
            else
                Line.Visible = false
            end
        end
    end
    
    -- Only auto-unlock if target actually dies, not if they just fail checks temporarily
    if CToggle and CTarget and not IsAlive(CTarget) then
        CToggle=false
        CTarget=nil; CachedAimPart=nil; CachedAimPosition=nil; CachedTracerPos=nil
        Line.Visible = false  -- Clear the tracer line immediately
    end
    
    if not (getgenv().DNS["Camlock"]["Enabled"] and cfg_cam()["Enabled"] and CToggle) then
        Line.Visible = false
    end
end))
 
