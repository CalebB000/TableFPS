local function GetFOVRadius(fov_cfg, distance)
    local dc = fov_cfg["DistanceConfiguration"]
    if dc and dc["Enabled"] and distance then
        local ranges = dc["Ranges"]
        if distance > 0 then
            for i = 1, #ranges do
                if distance <= ranges[i]["Max"] then return ranges[i]["Radius"] end
            end
        end
        -- If distance is 0 or no match found, use first range
        return ranges[1]["Radius"]
    end
    local wc = fov_cfg["WeaponConfiguration"]
    if wc and wc["Enabled"] then
        local tool = GetCurrentTool()
        if tool then
            local gun = wc[tool.Name]
            if gun then return gun["Radius"] end
        end
    end
    return fov_cfg["Radius"]
end
 
local function GetDistancePrediction(pred_cfg, distance)
    local dc = pred_cfg["Distance"]
    if not dc or not dc["Enabled"] then return nil end
    local ranges = dc["Ranges"]
    if not ranges then return nil end
    for i = 1, #ranges do
        if distance <= ranges[i]["Max"] then return ranges[i]["Basic"] end
    end
    return ranges[#ranges]["Basic"]
end
 
local function GetDistanceSmoothness(sm_cfg, distance)
    if not sm_cfg or not sm_cfg["Enabled"] then return nil end
    local ranges = sm_cfg["Ranges"]
    if not ranges then return nil end
    for i = 1, #ranges do
        if distance <= ranges[i]["Max"] then return ranges[i]["Smoothness"] end
    end
    return ranges[#ranges]["Smoothness"]
end
 
local function BasicPoint(part)
    if not part then return nil end
    local mr  = m.UnitRay
    local mp  = mr.Origin + (mr.Direction * (part.Position - mr.Origin).Magnitude)
    local pt  = (mp.Y >= (part.Position - part.Size/2).Y and mp.Y <= (part.Position + part.Size/2).Y)
        and (part.Position + vect3(0, -part.Position.Y + mp.Y, 0)) or part.Position
    local chk = RaycastParams.new()
    chk.FilterType = Enum.RaycastFilterType.Include
    chk.FilterDescendantsInstances = {part}
    local ray = ws:Raycast(mp, pt - mp, chk)
    if m.Target == part then return m.Hit.Position end
    if ray then return ray.Position end
    return m.Hit.Position
end
 
local function GetClosestPointInternal(character, cp_cfg, ref_x, ref_y)
    if not (character and character.Parent) then return nil end
    local mode    = cp_cfg["Mode"] or "Advanced"
    local scale   = cp_cfg["Scale"] or 5.5
    local density = math.clamp(cp_cfg["Density"] or 2, 1, 4)
    local sf      = math.clamp(scale, 0, 10) / 10
    local bd      = 1e9
    local bp, bpos
    local parts = {}
    for i = 1, #R15_PARTS do
        local part = character:FindFirstChild(R15_PARTS[i])
        if part and part:IsA("BasePart") then
            parts[#parts+1] = part
        end
    end
    if mode == "Basic" then
        for i = 1, #parts do
            local cl = BasicPoint(parts[i])
            if cl then
                local s = c:WorldToViewportPoint(cl)
                if s.Z > 0 then
                    local d = (s.X-ref_x)^2 + (s.Y-ref_y)^2
                    if d < bd then bd=d; bp=parts[i]; bpos=cl end
                end
            end
        end
    else
        local so = {}
        for j = 0, density-1 do so[j+1] = j / math.max(density-1, 1) end
        for i = 1, #parts do
            local part = parts[i]
            local size = part.Size
            local half = size * 0.5
            local cf   = part.CFrame
            local sh   = half * (1 - sf)
            for z = 1, density do
                local lz = math.clamp(-half.Z + so[z]*size.Z, -sh.Z, sh.Z)
                for y = 1, density do
                    local ly = math.clamp(-half.Y + so[y]*size.Y, -sh.Y, sh.Y)
                    for x = 1, density do
                        local lx = math.clamp(-half.X + so[x]*size.X, -sh.X, sh.X)
                        local wp = cf:PointToWorldSpace(vect3(lx,ly,lz))
                        local s  = c:WorldToViewportPoint(wp)
                        if s.Z > 0 then
                            local d = (s.X-ref_x)^2 + (s.Y-ref_y)^2
                            if d < bd then bd=d; bp=part; bpos=wp end
                        end
                    end
                end
            end
        end
    end
    if bp then return {Part=bp, Position=bpos} end
    local root = character:FindFirstChild("HumanoidRootPart")
    return root and {Part=root, Position=root.Position}
end
 
local function GetClosestPartForSilentAim(character)
    if not character then return nil end
    local cam = game:GetService("Workspace").CurrentCamera
    local mousePos = game:GetService("UserInputService"):GetMouseLocation()
    local cursorPos = Vector2.new(mousePos.X, mousePos.Y)
    local minDist = math.huge
    local closestPart = nil
    
    for _, partName in ipairs(R15_PARTS) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            local screenPos = cam:WorldToViewportPoint(part.Position)
            if screenPos.Z > 0 then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - cursorPos).Magnitude
                if dist < minDist then
                    minDist = dist
                    closestPart = part
                end
            end
        end
    end
    
    return closestPart
end
 
local function GetClosestPoint(character, cp_cfg)
    local mv = GetMouseVP()
    return GetClosestPointInternal(character, cp_cfg, mv.X, mv.Y)
end
 
local function GetPartFromList(character, parts_list)
    if not character or not parts_list then return nil end
    for i = 1, #parts_list do
        local part = character:FindFirstChild(parts_list[i])
        if part and part:IsA("BasePart") then return part end
    end
    return character:FindFirstChild("HumanoidRootPart")
end
 
local function GetVelocity(character)
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    return hrp and hrp.AssemblyLinearVelocity or vect3(0,0,0)
end
 
local function ApplyPrediction(position, velocity, pred_cfg, distance)
    if not position or not velocity or not pred_cfg then return position end
    if not pred_cfg["Enabled"] then return position end
    local scalar = pred_cfg["Basic"] or 0
    if pred_cfg["Distance"] and pred_cfg["Distance"]["Enabled"] then
        local dp = GetDistancePrediction(pred_cfg, distance or 0)
        if dp then scalar = dp end
    end
    return position + velocity * scalar
end
 
local function CheckAntiCurve(target_pos, ac_cfg)
    if not ac_cfg or not ac_cfg["Enabled"] then return false, 0 end
    local mag = (target_pos - m.Hit.Position).Magnitude / 10
    local ac  = ac_cfg["AngularCurve"] or 9.6
    local dd  = ac_cfg["DynamicDistance"]
    if dd and dd["Enabled"] then
        local hrp  = lplr.Character and lplr.Character:FindFirstChild("HumanoidRootPart")
        local dist = hrp and (hrp.Position - target_pos).Magnitude or 0
        local t    = math.clamp(dist / (dd["MaxDistance"] or 100), 0, 1)
        ac = (dd["MinRadius"] or 50) + ((dd["MaxRadius"] or 150) - (dd["MinRadius"] or 50)) * t
    end
    if ac_cfg["Mode"] == "2D" then
        local sp = c:WorldToViewportPoint(target_pos)
        local mv = GetMouseVP()
        local sd = (vect2(sp.X,sp.Y) - mv).Magnitude / 10
        if ac_cfg["DebugOutput"] then print(string.format("[AntiCurve 2D] %.2f | %.2f | %s", sd, ac, tostring(sd>ac))) end
        return sd > ac, sd
    end
    if ac_cfg["DebugOutput"] then print(string.format("[AntiCurve 3D] %.2f | %.2f | %s", mag, ac, tostring(mag>ac))) end
    return mag > ac, mag
end
 
local function GetTargetDistance(target)
    if not target or not target.Character then return 0 end
    local hrp  = target.Character:FindFirstChild("HumanoidRootPart")
    local lhrp = lplr.Character and lplr.Character:FindFirstChild("HumanoidRootPart")
    if hrp and lhrp then return (hrp.Position - lhrp.Position).Magnitude end
    return 0
end
 
local function DoWallCheck(target_part)
    if not getgenv().DNS["Silent"]["WallCheck"] and not getgenv().DNS["Camlock"]["WallCheck"] then
        return true
    end
    if not target_part or not target_part:IsA("BasePart") then return false end
    
    -- Filter out ALL player characters so wallcheck ignores players completely
    local chars_to_filter = {lplr.Character, c}
    for _, player in ipairs(plrs:GetPlayers()) do
        if player.Character then
            table.insert(chars_to_filter, player.Character)
        end
    end
    
    RayParams.FilterDescendantsInstances = chars_to_filter
    local origin = c.CFrame.Position
    local dir    = target_part.Position - origin
    local result = ws:Raycast(origin, dir, RayParams)
    
    -- If raycast hits ANYTHING (non-player object = wall), wallcheck fails
    -- If raycast hits NOTHING (clear line of sight through/around players), wallcheck passes
    if result then
        -- Hit something - check if it's a player part (shouldn't happen due to filter, but double-check)
        local hit_model = result.Instance:FindFirstAncestorOfClass("Model")
        if hit_model and plrs:GetPlayerFromCharacter(hit_model) then
            -- Hit a player somehow - treat as no wall
            return true
        end
        -- Hit a non-player object (wall/building)
        return false
    end
    
    -- Nothing blocking - clear line of sight
    return true
end
 
local function PassesChecks(player)
    if not player or not player.Character then return false end
    local char = player.Character
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local be   = char:FindFirstChild("BodyEffects")
    local chk  = cfg_checks()
    if not chk["Enabled"] then return true end
    if not hum or hum.Health <= 0 then return false end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return false end
    if chk["Knocked"] and be then
        local ko   = be:FindFirstChild("K.O")
        local dead = be:FindFirstChild("Dead")
        if ko   and ko.Value   == true then return false end
        if dead and dead.Value == true then return false end
    end
    if chk["Grabbed"] and be then
        local g = be:FindFirstChild("Grabbed")
        if g and g.Value == true then return false end
    end
    if chk["ForceField"] and char:FindFirstChildOfClass("ForceField") then return false end
    if chk["CrewCheck"] and player.Team and lplr.Team and player.Team == lplr.Team then return false end
    if chk["AntiGroundShots"] then
        local thrp = char:FindFirstChild("HumanoidRootPart")
        local lhrp = lplr.Character and lplr.Character:FindFirstChild("HumanoidRootPart")
        if thrp and lhrp then
            local tv = thrp.Velocity
            if hum.FloorMaterial ~= Enum.Material.Air
                and (lhrp.Position.Y - thrp.Position.Y) > (chk["AntiGroundThreshold"] or 3.5)
                and math.abs(tv.Y) < 5
            then return false end
            if tv.Magnitude > 100 then return false end
        end
    end
    return true
end
 
local function IsAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return false end
    local be = player.Character:FindFirstChild("BodyEffects")
    if be then
        if be:FindFirstChild("K.O") and be["K.O"].Value == true then return false end
        if be:FindFirstChild("Dead") and be.Dead.Value == true then return false end
    end
    return true
end
 
local function GetCameraMode()
    local focus = c.Focus
    if not focus then return "Third Person" end
    local camPos = c.CFrame.Position
    local focusPos = focus.Position
    local dist = (camPos - focusPos).Magnitude
    if dist < 1.5 then  -- More lenient threshold for shift-lock/scoping
        return "First Person"
    else
        return "Third Person"
    end
end
 
local function GetBoxFOVBounds(fov_cfg, hrp)
    local screen, on = c:WorldToViewportPoint(hrp.Position)
    if not on then return nil end
    local scale = (hrp.Size.Y * c.ViewportSize.Y) / (screen.Z * 2) * 80 / c.FieldOfView
    local w     = fov_cfg["Box"]["Width"]  * scale
    local h     = fov_cfg["Box"]["Height"] * scale
    return {
        X = screen.X - w/2,
        Y = screen.Y - h/2,
        W = w,
        H = h,
        CX = screen.X,
        CY = screen.Y,
    }
end
 
local function IsMouseInBoxFOV(bounds)
    if not bounds then return false end
    local mv = GetMouseVP()
    return mv.X >= bounds.X and mv.X <= bounds.X + bounds.W
       and mv.Y >= bounds.Y and mv.Y <= bounds.Y + bounds.H
end
 
local function IsMouseInCircleFOV(fov_cfg, hrp, distance)
    local radius = GetFOVRadius(fov_cfg, distance)
    local pos    = c:WorldToViewportPoint(hrp.Position)
    return (GetMouseVP() - vect2(pos.X, pos.Y)).Magnitude < radius
end
local function GetClosestPlayerToMouse()
    local mv = GetMouseVP()
    local closest = nil
    local bestDist = math.huge
 
    for _, player in ipairs(plrs:GetPlayers()) do
        if player == lplr then continue end
        if not IsAlive(player) or not PassesChecks(player) then continue end
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local screen, on = c:WorldToViewportPoint(hrp.Position)
        if not on then continue end
        local dist = (vect2(screen.X, screen.Y) - mv).Magnitude
        if dist < bestDist then
            bestDist = dist
            closest = player
        end
    end
    return closest
end
local function InSilentFOV(target, distance)
    local sfov = cfg_sfov()
    if not sfov["Enabled"] then return true end
    local hrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Check if target is on screen
    local screen_pos = c:WorldToViewportPoint(hrp.Position)
    if not screen_pos or screen_pos.Z <= 0 then return false end
    
    -- Get FOV radius from center of screen
    local radius = GetFOVRadius(sfov, distance)
    local screen_center = vect2(c.ViewportSize.X / 2, c.ViewportSize.Y / 2)
    local target_screen = vect2(screen_pos.X, screen_pos.Y)
    
    -- Check if target is within FOV radius from center of screen
    return (target_screen - screen_center).Magnitude < radius
end
 
local function InCamlockFOV(target, distance)
    local cfov = cfg_cfov()
    if not cfov["Enabled"] or not cfov["UseFOV"] then return true end
    local hrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    if cfov["Type"] == "Box" then
        local bounds = GetBoxFOVBounds(cfov, hrp)
        return IsMouseInBoxFOV(bounds)
    end
    return IsMouseInCircleFOV(cfov, hrp, distance)
end
 
local function GetClosestPlayerSpheircal(fov_cfg, distance)
    local mv      = GetMouseVP()
    local bd      = math.huge
    local best    = nil
    local is_box  = fov_cfg["Type"] == "Box"
    local radius  = not is_box and GetFOVRadius(fov_cfg, distance) or math.huge
 
    for _, player in ipairs(plrs:GetPlayers()) do
        if player == lplr then continue end
        if not IsAlive(player) or not PassesChecks(player) then continue end
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        
        -- NEW: Skip players behind walls if wallcheck enabled
        if getgenv().DNS["Silent"]["WallCheck"] then
            local head = player.Character:FindFirstChild("Head")
            if head and not DoWallCheck(head) then continue end
        end
        
        local screen, on = c:WorldToViewportPoint(hrp.Position)
        if not on then continue end
        local mag = (vect2(screen.X, screen.Y) - mv).Magnitude
        if is_box then
            local bounds = GetBoxFOVBounds(fov_cfg, hrp)
            if bounds and IsMouseInBoxFOV(bounds) and mag < bd then
                bd = mag; best = player
            end
        else
            if mag < radius and mag < bd then
                bd = mag; best = player
            end
        end
    end
    return best
end
 
local function GetSilentAimPosition(character, distance)
    if not character then return nil, nil end
    local s        = cfg_silent()
    local pred_cfg = s["Prediction"]
    local vel      = GetVelocity(character)
    local cp_cfg   = s["ClosestPoint"]
    local bp, bpos
    
    -- CLOSEST PART MODE: Find closest body part to cursor
    if s["ClosestPart"]["Enabled"] then
        bp = GetClosestPartForSilentAim(character)
        if bp then bpos = bp.Position end
    elseif cp_cfg["Enabled"] then
        local r = GetClosestPoint(character, cp_cfg)
        if r then bp=r.Part; bpos=r.Position end
    else
        bp = GetPartFromList(character, s["Parts"])
        if bp then bpos = bp.Position end
    end
    if not (bp and bpos) then return nil, nil end
    if getgenv().DNS["Silent"]["WallCheck"] and not DoWallCheck(bp) then return nil, nil end
    return bp, ApplyPrediction(bpos, vel, pred_cfg, distance)
end
 
local function GetCamlockPosition(character, distance)
    if not character then return nil, nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil end
    local cam    = cfg_cam()
    local cp_cfg = cam["ClosestPoint"]
    local vel    = GetVelocity(character)
    local bp, bpos
    if cp_cfg["Enabled"] then
        local mv = GetMouseVP()
        local r  = GetClosestPointInternal(character, cp_cfg, mv.X, mv.Y)
        if r then bp=r.Part; bpos=r.Part.Position end
    else
        bp = GetPartFromList(character, cam["Parts"])
        if bp then bpos = bp.Position end
    end
    if not bp then return hrp, ApplyPrediction(hrp.Position, vel, cam["Prediction"], distance) end
    -- If wallcheck enabled and fails, stop camlock movement (return nil)
    if getgenv().DNS["Camlock"]["WallCheck"] and not DoWallCheck(bp) then 
        return nil, nil
    end
    return bp, ApplyPrediction(bpos, vel, cam["Prediction"], distance)
end
 
local function GetTracerPosition(character, distance)
    if not character then return nil end
    local s      = cfg_silent()
    local vel    = GetVelocity(character)
    local cp_cfg = s["ClosestPoint"]
    if cp_cfg["Enabled"] then
        local r = GetClosestPoint(character, cp_cfg)
        if not r then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            return hrp and hrp.Position
        end
        return ApplyPrediction(r.Position, vel, s["Prediction"], distance)
    end
    local part = GetPartFromList(character, s["Parts"])
    return part and ApplyPrediction(part.Position, vel, s["Prediction"], distance)
end
 
local SilentTarget = nil

local function GetSilentTarget()
    local autolock = cfg_silent()["AutoLock"]
    
    if not autolock or not autolock["Enabled"] then
        return CToggle and CTarget or nil
    end
    
    local mode = autolock["Mode"] or "FOV"
    
    if mode == "Always" then
        return GetClosestPlayerToMouse()
    elseif mode == "FOV" then
        local dist = SilentTarget and GetTargetDistance(SilentTarget) or 0
        return GetClosestPlayerSpheircal(cfg_sfov(), dist)
    end
    
    return nil
end

local function UpdateCachedAim()
    CachedAimPart     = nil
    CachedAimPosition = nil
    CachedTracerPos   = nil
    
    if not getgenv().DNS["Silent"]["Enabled"] then return end
    if not cfg_silent()["Enabled"] then return end
    
    SilentTarget = GetSilentTarget()
    
    if not SilentTarget or not SilentTarget.Character then return end
    if not IsAlive(SilentTarget) then return end
    
    local dist = GetTargetDistance(SilentTarget)
    
    local autolock = cfg_silent()["AutoLock"]
    if autolock and autolock["Enabled"] and autolock["Mode"] == "FOV" then
        if not InSilentFOV(SilentTarget, dist) then return end
    end
    
    local part, pos = GetSilentAimPosition(SilentTarget.Character, dist)
    
    if part and pos and typeof(pos) == "Vector3" and typeof(part) == "Instance" then
        CachedAimPart = part
        CachedAimPosition = pos
        
        local tp = GetTracerPosition(SilentTarget.Character, dist)
        if tp then CachedTracerPos = tp end
    end
end
 
local function FindTarget()
    local sfov = cfg_sfov()
    local dist = CTarget and GetTargetDistance(CTarget) or 0
    return GetClosestPlayerSpheircal(sfov, dist)
end
 
local function GetClosestPlayerInFOV()
    local sfov = cfg_sfov()
    local dist = CTarget and GetTargetDistance(CTarget) or 0
    local p    = GetClosestPlayerSpheircal(sfov, dist)
    if p and p.Character then
        return p.Character:FindFirstChild("HumanoidRootPart")
    end
    return nil
end
 
