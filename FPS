local function DNS_Cleanup()
    for _, conn in ipairs(DNS_Connections) do pcall(function() conn:Disconnect() end) end
    for _, draw in ipairs(DNS_Drawings)    do pcall(function() draw:Remove()     end) end
    if DNS_GUI then pcall(function() DNS_GUI:Destroy() end) end
    DNS_Connections = {}
    DNS_Drawings    = {}
    DNS_GUI         = nil
    if getgenv().DNS_OldNamecall then
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        mt.__namecall = getgenv().DNS_OldNamecall
        setreadonly(mt, true)
        getgenv().DNS_OldNamecall = nil
    end
    if getgenv().DNS_OldRandom then
        hookfunction(math.random, getgenv().DNS_OldRandom)
        getgenv().DNS_OldRandom = nil
    end
    if getgenv().DNS_GunHandlerOriginal and getgenv().DNS_GunHandler then
        getgenv().DNS_GunHandler.shoot   = getgenv().DNS_GunHandlerOriginal
        getgenv().DNS_GunHandler         = nil
        getgenv().DNS_GunHandlerOriginal = nil
    end
    getgenv().DNSload     = nil
    getgenv().DNS_Cleanup = nil
end

