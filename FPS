            print("[DNS] ClientBullet enabled: " .. cb_mode)
        elseif not cb_enabled and ClientBulletHooked then
            -- Disable ClientBullet - getAim hook handles Silent Aim with gun spread
            gun_handler.shoot = orig_shoot
            ClientBulletHooked = false
            print("[DNS] ClientBullet disabled - Silent Aim active via getAim")
        end
    end))
    
    getgenv().DNS_GunHandler        = gun_handler
