do
    local mt  = getrawmetatable(game)
    local old = mt.__namecall
    setreadonly(mt, false)
    getgenv().DNS_OldNamecall = old
 
    local function is_mouse_arg(v)
        if typeof(v) == "Vector3" then return true end
        if typeof(v) == "Ray"     then return true end
        if typeof(v) == "CFrame" and math.abs(v.LookVector.Y) < 0.98 then return true end
        return false
    end
 
    local function redirect_args(args, aim_pos)
        for i = 1, #args do
            local v = args[i]
            if typeof(v) == "Vector3" then
                args[i] = aim_pos
            elseif typeof(v) == "CFrame" then
                args[i] = cnew(aim_pos)
            elseif typeof(v) == "table" then
                for k, tv in pairs(v) do
                    if typeof(tv) == "Vector3" then v[k] = aim_pos end
                    if typeof(tv) == "CFrame"  then v[k] = cnew(aim_pos) end
                end
            end
        end
        return args
    end
 
    mt.__namecall = newcclosure(function(self, ...)
        if checkcaller() then return old(self, ...) end
        local args   = {...}
        local method = getnamecallmethod()
 
        if method == "FireServer" and self == MainEvent then
            local s         = cfg_silent()
            local fa        = args[1]
            local ac        = s["AntiCurve"]
            local hc        = s["Hitchance"] or 100
            local silent_on = getgenv().DNS["Silent"]["Enabled"]
                and s["Enabled"]
                and not gun_handler_active
                and CachedAimPosition
                and math.random(100) <= hc
                and (not getgenv().DNS["Silent"]["WeaponCheck"] or CachedHasWeapon)
 
            -- Der Hood detection (obfuscated shooting string)
            if fa == "D3RHooDMSOUEPoS233^+" then
                if silent_on then
                    local curved = CheckAntiCurve(CachedAimPosition, ac)
                    if curved then return old(self, table.unpack(args)) end
                    args[2] = CachedAimPosition
                    return old(self, table.unpack(args))
                end
                return old(self, table.unpack(args))
            end
 
            if IsDaHood then
                if fa == "UpdateMousePosI2" then
                    if cfg()["Silent"]["AntiAimViewer"] then return old(self, ...) end
                    if silent_on then
                        local curved = CheckAntiCurve(CachedAimPosition, ac)
                        if curved then return old(self, "UpdateMousePosI2", m.Hit.Position) end
                        return old(self, "UpdateMousePosI2", CachedAimPosition)
                    end
                    return old(self, "UpdateMousePosI2", m.Hit.Position)
                end
                if fa == "UpdateMousePos" then return old(self, ...) end
            else
                local has_mouse = false
                for i = 1, #args do
                    if is_mouse_arg(args[i]) then has_mouse=true; break end
                end
                if has_mouse then
                    if cfg()["Silent"]["AntiAimViewer"] then return old(self, ...) end
                    if silent_on then
                        local curved = CheckAntiCurve(CachedAimPosition, ac)
                        if curved then
                            args = redirect_args(args, m.Hit.Position)
                            return old(self, table.unpack(args))
                        end
                        args = redirect_args(args, CachedAimPosition)
                        return old(self, table.unpack(args))
                    end
                    args = redirect_args(args, m.Hit.Position)
                    return old(self, table.unpack(args))
                end
            end
        end
 
        local sc = cfg_silent()
        if not gun_handler_active
            and getgenv().DNS["Silent"]["Enabled"]
            and sc["Enabled"]
            and CachedAimPart
            and CachedAimPosition
            and math.random(100) <= (sc["Hitchance"] or 100)
            and (not getgenv().DNS["Silent"]["WeaponCheck"] or CachedHasWeapon)
        then
            local aim = CachedAimPosition
            if self == ws then
                local ml = method:lower()
                if ml == "raycast" then
                    args[2] = (aim - args[1]).Unit * 10000
                    return old(self, table.unpack(args))
                elseif ml == "shapecast" then
                    args[2] = (aim - args[1].Position).Unit * 10000
                    return old(self, table.unpack(args))
                elseif ml == "spherecast" then
                    args[3] = (aim - args[1]).Unit * 10000
                    return old(self, table.unpack(args))
                elseif ml == "blockcast" then
                    args[3] = (aim - args[1].Position).Unit * 10000
                    return old(self, table.unpack(args))
                end
            end
        end
 
        return old(self, ...)
    end)
 
    setreadonly(mt, true)
end
 
