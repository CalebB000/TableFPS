        local screenGui = Instance.new("ScreenGui")
        screenGui.Name = "ESP_FilterGUI"
        screenGui.ResetOnSpawn = false
        screenGui.Parent = game:GetService("CoreGui")
        
        -- Main frame (grey background)
        local mainFrame = Instance.new("Frame")
        mainFrame.Name = "MainFrame"
        mainFrame.Size = UDim2.new(0, 200, 0, 400)
        mainFrame.Position = UDim2.new(0, 10, 0, 50)
        mainFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        mainFrame.BorderColor3 = Color3.fromRGB(100, 100, 100)
        mainFrame.BorderSizePixel = 1
        mainFrame.Parent = screenGui
        
        -- Server button at top
        local serverButton = Instance.new("TextButton")
        serverButton.Name = "ServerButton"
        serverButton.Size = UDim2.new(1, -2, 0, 30)
        serverButton.Position = UDim2.new(0, 1, 0, 1)
        serverButton.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        serverButton.BorderColor3 = Color3.fromRGB(120, 120, 120)
        serverButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        serverButton.TextSize = 12
        serverButton.Font = Enum.Font.GothamBold
        serverButton.Text = "ESP Everyone"
        serverButton.Parent = mainFrame
        
        serverButton.MouseButton1Click:Connect(function()
            -- Add all players to ESP
            for _, player in pairs(plrs:GetPlayers()) do
                if player ~= lplr and player.Character then
                    local found = false
                    for _, name in pairs(_G.ESPFilteredPlayers) do
                        if name == player.Name then
                            found = true
                            break
                        end
                    end
                    if not found then
                        table.insert(_G.ESPFilteredPlayers, player.Name)
                    end
                end
            end
        end)
        
        -- Reset button
        local resetButton = Instance.new("TextButton")
        resetButton.Name = "ResetButton"
        resetButton.Size = UDim2.new(1, -2, 0, 25)
        resetButton.Position = UDim2.new(0, 1, 0, 33)
        resetButton.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        resetButton.BorderColor3 = Color3.fromRGB(100, 100, 100)
        resetButton.TextColor3 = Color3.fromRGB(200, 200, 200)
        resetButton.TextSize = 11
        resetButton.Font = Enum.Font.Gotham
        resetButton.Text = "Clear All"
        resetButton.Parent = mainFrame
        
        resetButton.MouseButton1Click:Connect(function()
            _G.ESPFilteredPlayers = {}
        end)
        
        -- Scroll frame for player list
        local scrollFrame = Instance.new("ScrollingFrame")
        scrollFrame.Name = "ScrollFrame"
        scrollFrame.Size = UDim2.new(1, -2, 1, -62)
        scrollFrame.Position = UDim2.new(0, 1, 0, 60)
        scrollFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        scrollFrame.BorderColor3 = Color3.fromRGB(80, 80, 80)
        scrollFrame.BorderSizePixel = 1
        scrollFrame.ScrollBarThickness = 6
        scrollFrame.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 100)
        scrollFrame.CanvasSize = UDim2.new(1, 0, 0, 0)
        scrollFrame.Parent = mainFrame
        
        -- Add player buttons - only update when needed
        local function RefreshPlayerList()
            scrollFrame:ClearAllChildren()
            local yPosition = 0
            
            for _, player in pairs(plrs:GetPlayers()) do
                if player ~= lplr and player.Character then
                    local playerName = player.Name
                    
                    local isESPd = false
                    for _, name in pairs(_G.ESPFilteredPlayers) do
                        if name == playerName then
                            isESPd = true
                            break
                        end
                    end
                    
                    local playerBtn = Instance.new("TextButton")
                    playerBtn.Name = playerName
                    playerBtn.Size = UDim2.new(1, 0, 0, 25)
                    playerBtn.Position = UDim2.new(0, 0, 0, yPosition)
                    playerBtn.BackgroundColor3 = isESPd and Color3.fromRGB(100, 100, 100) or Color3.fromRGB(60, 60, 60)
                    playerBtn.BorderSizePixel = 0
                    playerBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                    playerBtn.TextSize = 11
                    playerBtn.Font = Enum.Font.Gotham
                    playerBtn.Text = isESPd and ("✓ " .. playerName) or ("  " .. playerName)
                    playerBtn.Parent = scrollFrame
                    
                    -- Create separate toggle function with proper closure
                    local function ToggleESP()
                        local found = false
                        local foundIndex = 0
                        
                        for i, name in ipairs(_G.ESPFilteredPlayers) do
                            if name == playerName then
                                found = true
                                foundIndex = i
                                break
                            end
                        end
                        
                        if found then
                            -- Remove from list
                            table.remove(_G.ESPFilteredPlayers, foundIndex)
                        else
                            -- Add to list
                            table.insert(_G.ESPFilteredPlayers, playerName)
                        end
                    end
                    
                    playerBtn.MouseButton1Click:Connect(ToggleESP)
                    
                    yPosition = yPosition + 25
                end
            end
            
            scrollFrame.CanvasSize = UDim2.new(1, 0, 0, math.max(yPosition, 1))
        end
        
        RefreshPlayerList()
        
        -- Update player list periodically (every 30 frames, ~0.5 seconds)
        local updateCounter = 0
        table.insert(DNS_Connections, rs.Heartbeat:Connect(function()
            if ESP_GUIVisible and scrollFrame and scrollFrame.Parent then
                updateCounter = updateCounter + 1
                if updateCounter >= 30 then
                    updateCounter = 0
                    pcall(function()
                        RefreshPlayerList()
                    end)
                end
            end
        end))
        
        return screenGui
    end
    
    -- Toggle with configurable key
    table.insert(DNS_Connections, uis.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == cfg_esp()["ToggleKey"] then
            ESP_ShowGUI = not ESP_ShowGUI
            if ESP_ShowGUI then
                if not ESP_GUI then
                    ESP_GUI = CreateFilterGUI()
                end
                ESP_GUI.Enabled = true
                ESP_GUIVisible = true
            else
                if ESP_GUI then
                    ESP_GUI.Enabled = false
                end
                ESP_GUIVisible = false
            end
        end
    end))
    
    -- Initialize existing players
    for _, player in pairs(plrs:GetPlayers()) do
        if player ~= lplr then
            CreatePlayerESP(player)
        end
    end
    
    -- New player connects - force GUI refresh
    table.insert(DNS_Connections, plrs.PlayerAdded:Connect(function(player)
        CreatePlayerESP(player)
        if ESP_GUI and ESP_GUIVisible then
            task.wait(0.1)
            -- Recreate the GUI to refresh player list
            local wasVisible = ESP_GUIVisible
            if ESP_GUI then
                pcall(function() ESP_GUI:Destroy() end)
            end
            ESP_GUI = CreateFilterGUI()
            ESP_GUI.Enabled = wasVisible
        end
    end))
    
    -- Player disconnects - force GUI refresh
    table.insert(DNS_Connections, plrs.PlayerRemoving:Connect(function(player)
        if ESP_Players[player] then
            for _, draw in pairs(ESP_Players[player]) do
                pcall(function() draw:Remove() end)
            end
            ESP_Players[player] = nil
        end
        if ESP_GUI and ESP_GUIVisible then
            task.wait(0.1)
            -- Recreate the GUI to refresh player list
            local wasVisible = ESP_GUIVisible
            if ESP_GUI then
                pcall(function() ESP_GUI:Destroy() end)
            end
            ESP_GUI = CreateFilterGUI()
            ESP_GUI.Enabled = wasVisible
        end
    end))
    
    -- Main ESP update loop - only draw players in filter
    table.insert(DNS_Connections, rs.RenderStepped:Connect(function()
        for player, drawingInstances in pairs(ESP_Players) do
            if not player or not player.Character then continue end
            
            -- Check if player is in filter list
            local shouldDraw = false
            for _, filteredName in pairs(_G.ESPFilteredPlayers) do
                if player.Name == filteredName then
                    shouldDraw = true
                    break
                end
            end
            
            if not shouldDraw then
                for _, draw in pairs(drawingInstances) do
                    pcall(function() draw.Visible = false end)
                end
                continue
            end
            
            local character = player.Character
            local hrp = character:FindFirstChild("HumanoidRootPart")
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            
            if not hrp or not humanoid then continue end
            
            local screenPos = c:WorldToViewportPoint(hrp.Position)
            local distFromChar = (c.CFrame.Position - hrp.Position).Magnitude
            
            -- Distance culling
            if cfg_esp()["RenderDistance"] and distFromChar > cfg_esp()["RenderDistance"] then
                for _, draw in pairs(drawingInstances) do
                    pcall(function() draw.Visible = false end)
                end
                continue
            end
            
            if screenPos.Z > 0 then  -- On screen
                local charSize = (c:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0)).Y - c:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.6, 0)).Y) / 2
                local boxSize = Vector2.new(math.floor(charSize * 1.1), math.floor(charSize * 1.9))
                local boxPosition = Vector2.new(math.floor(screenPos.X - charSize * 1.1 / 2), math.floor(screenPos.Y - charSize * 1.6 / 2))
                
                local espColor = cfg_esp()["Color"]
                
                -- Draw box
                if cfg_esp()["ShowBoxes"] then
                    drawingInstances.Box.Size = boxSize
                    drawingInstances.Box.Position = boxPosition
                    drawingInstances.Box.Visible = true
                    drawingInstances.Box.Color = espColor
                    drawingInstances.Box.Transparency = cfg_esp()["Transparency"]
                    
                    drawingInstances.BoxOutline.Size = boxSize
                    drawingInstances.BoxOutline.Position = boxPosition
                    drawingInstances.BoxOutline.Visible = true
                    drawingInstances.BoxOutline.Transparency = cfg_esp()["Transparency"]
                else
                    drawingInstances.Box.Visible = false
                    drawingInstances.BoxOutline.Visible = false
                end
                
                -- Draw name
                if cfg_esp()["ShowNames"] then
                    drawingInstances.Name.Visible = true
                    drawingInstances.Name.Text = character.Humanoid.DisplayName
                    drawingInstances.Name.Position = Vector2.new(boxSize.X / 2 + boxPosition.X, boxPosition.Y - 16)
                    drawingInstances.Name.Color = espColor
                    drawingInstances.Name.Transparency = cfg_esp()["Transparency"]
                else
                    drawingInstances.Name.Visible = false
                end
            else
                for _, draw in pairs(drawingInstances) do
                    pcall(function() draw.Visible = false end)
                end
            end
        end
    end))
end

-- ========== TRYHARD ANIMATIONS IMPLEMENTATION ==========
if cfg_misc()["TryhardAnimations"]["Enabled"] then
    local lastCharacter = nil
    local animCounter = 0
    
    table.insert(DNS_Connections, rs.Stepped:Connect(function()
        local character = lplr.Character
        
        -- Update on character change
        if character ~= lastCharacter then
            lastCharacter = character
            if character and character:FindFirstChild("Animate") then
                local anim = character.Animate
                anim.run.RunAnim.AnimationId = cfg_misc()["TryhardAnimations"]["RunAnimation"]
                anim.jump.JumpAnim.AnimationId = cfg_misc()["TryhardAnimations"]["JumpAnimation"]
                anim.fall.FallAnim.AnimationId = cfg_misc()["TryhardAnimations"]["FallAnimation"]
            end
        end
        
        -- Also update every 6 frames
        animCounter = (animCounter + 1) % 6
        if animCounter == 0 and character and character:FindFirstChild("Animate") then
            local anim = character.Animate
            anim.run.RunAnim.AnimationId = cfg_misc()["TryhardAnimations"]["RunAnimation"]
            anim.jump.JumpAnim.AnimationId = cfg_misc()["TryhardAnimations"]["JumpAnimation"]
            anim.fall.FallAnim.AnimationId = cfg_misc()["TryhardAnimations"]["FallAnimation"]
        end
    end))
end

