                        or c.CFrame.Position
                    
                    results[1] = CachedAimPosition
                    results[2] = CachedAimPart
                    
                    -- For Normal mode: don't override results[3], keep gun spread
                    -- For Sniper/LegitSniper/LegitRedirection: override for perfect bullets
                    if cb_mode == "Normal" then
                        -- Keep gun spread, don't override results[3]
                    else
                        -- Sniper/LegitSniper/LegitRedirection: perfect direction
                        results[3] = (CachedAimPosition - muz).Unit
                    end
                end
                
                return table.unpack(results)
            end
            
